package tests;

import java.util.Arrays;

public class Solutions {
public static int threeSumClosest(int[] nums,int target) {
	Arrays.sort(nums);
	int n=nums.length;
	int closestSum=nums[0]+nums[1]+nums[2];
	for(int i=0;i<n-2;i++) {
		int left=i+1;
		int right=n-1;
		while(left<right) {
			int currentSum=nums[i]+nums[left]+nums[right];
			if(Math.abs(currentSum-target)<
					Math.abs(closestSum-target)) {
				closestSum=currentSum;
			}
			if(currentSum<target) {
				left++;
			}else if(currentSum>target) {
				right--;
			}else {
				return currentSum;
			}
		}
	}
	return closestSum;
}
	public static void main(String[] args) {
		// TODO Auto-generated method stub
int nums1[]= {-1,2,1,-4};
int target1=1;
int result1=threeSumClosest(nums1,target1);
System.out.println("Closest sum (Example1):"+result1);
int nums2[]= {0,0,0};
int target2=1;
int result2=threeSumClosest(nums2,target2);
System.out.println("Closest sum (Example2):"+result2);
	}
}
